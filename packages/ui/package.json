{
  "name": "@demo/ui",
  "version": "0.0.0",
  "private": true,
  "description": "Demo UI Library",
  "license": "MIT",
  "scripts": {
    "start-storybook": "storybook dev --port 4001 --quiet",
    "test": "vitest components --update --run",
    "test-ci": "vitest components --run",
    "typecheck": "tsc",
    "vrtest-regression": "pnpm exec reg-suit run",
    "vrtest-setup": "storybook build --quiet --output-dir ./build",
    "vrtest-server": "http-server ./build -p 4001",
    "vrtest-snapshot": "start-server-and-test vrtest-server http://127.0.0.1:4001 'pnpm exec playwright test --update-snapshots --pass-with-no-tests'"
  },
  "devDependencies": {
    "http-server": "^14.1.1",
    "reg-notify-github-plugin": "^0.12.1",
    "reg-simple-keygen-plugin": "0.12.1",
    "reg-suit": "0.12.1",
    "start-server-and-test": "^2.0.0"
  },
  "engines": {
    "node": "^22",
    "pnpm": ">=10"
  }
}
