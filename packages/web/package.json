{
  "name": "@demo/web",
  "version": "0.0.0",
  "private": true,
  "description": "Demo Web",
  "license": "MIT",
  "scripts": {
    "build": "next build",
    "start": "next dev",
    "start-storybook": "storybook dev --port 3001 --quiet",
    "test": "vitest src --update --run",
    "test-ci": "vitest src --run",
    "typecheck": "tsc",
    "a11y-check": "pnpm exec playwright test snapshot/a11y.test.ts",
    "storybook-coverage": "start-server-and-test vrtest-server http://127.0.0.1:3001 'pnpm exec test-storybook --url http://127.0.0.1:3001 --coverage --maxWorkers=5'",
    "create-coverage-report": "npx nyc report --reporter=text -t coverage/storybook --report-dir coverage/storybook",
    "vrtest-regression": "pnpm exec reg-suit run",
    "vrtest-setup": "storybook build --quiet --output-dir ./build",
    "vrtest-server": "http-server ./build -p 3001",
    "vrtest-a11y": "start-server-and-test vrtest-server http://127.0.0.1:3001 'pnpm a11y-check --reporter=snapshot/slack.ts,html'",
    "vrtest-snapshot": "start-server-and-test vrtest-server http://127.0.0.1:3001 'pnpm exec playwright test snapshot/snapshot.test.ts --update-snapshots --pass-with-no-tests'"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.1.0",
    "@types/node": "^18.15.13",
    "@types/react": "18.0.38",
    "@types/react-dom": "18.0.11",
    "autoprefixer": "10.4.14",
    "jotai": "^2.5.1",
    "lodash": "^4.17.21",
    "next": "^16.1.5",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.43.9",
    "typescript": "5.9.3",
    "yup": "^1.1.1"
  },
  "engines": {
    "node": "^22",
    "pnpm": ">=10"
  },
  "devDependencies": {
    "http-server": "^14.1.1",
    "reg-notify-github-plugin": "^0.12.1",
    "reg-simple-keygen-plugin": "0.12.1",
    "reg-suit": "0.12.1",
    "start-server-and-test": "^2.0.0"
  }
}
