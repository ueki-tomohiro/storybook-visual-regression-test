{
  "name": "@demo/api",
  "version": "0.0.0",
  "private": true,
  "description": "Demo API Library",
  "license": "MIT",
  "scripts": {
    "format": "prettier 'lib/**/*.ts' --write",
    "generate": "pnpm generate-api && pnpm lint && pnpm format",
    "generate-api": "cd ../../tools/api-client-generator && pnpm generate",
    "lint": "eslint . --ext .jsx,.js,.tsx,.ts --cache --fix",
    "test": "vitest src --update --run --passWithNoTests",
    "test-ci": "vitest src --run --passWithNoTests",
    "typecheck": "tsc"
  },
  "dependencies": {
    "@faker-js/faker": "^8.4.1",
    "@tanstack/react-query": "^4.29.3",
    "@types/promise-retry": "^1.1.3",
    "http-status": "^1.6.2",
    "msw": "^2.12.10",
    "promise-retry": "^2.0.1",
    "ts-custom-error": "^3.3.1",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": "^22",
    "pnpm": ">=10"
  }
}
